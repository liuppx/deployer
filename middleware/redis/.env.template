# 使用系统工具生成密码：
# openssl rand -base64 24 | tr -dc 'A-Za-z0-9' | head -c 24; echo
REDIS_PASSWORD=YourStrongPassword123!
# 可选：集群节点列表（逗号分隔），默认 127.0.0.1:6379
REDIS_NODES=127.0.0.1:6379
# 可选：redis-cli 执行模式（auto/local/docker）
REDIS_CLI_MODE=auto
# 可选：期望模式（auto/cluster/standalone），默认 auto
REDIS_EXPECT_MODE=auto
